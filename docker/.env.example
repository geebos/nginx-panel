# Optional: public/LAN IP (or hostname) of this host so remote browsers can open
# the panel before a manager domain is bound. Comma or space separated.
# Always keeps 127.0.0.1 and localhost as well.
# BOOTSTRAP_EXTRA_HOSTS=203.0.113.10
# BOOTSTRAP_EXTRA_HOSTS=203.0.113.10,10.0.0.5
#
# Optional legacy seed for upgrades that already had a public manager hostname.
# Greenfield installs can leave these unset and use only http://127.0.0.1 / localhost
# (plus BOOTSTRAP_EXTRA_HOSTS if set), then bind a public hostname under Settings → Manager.
# MANAGER_HOST=manager.example.com
# MANAGER_URL=https://manager.example.com
