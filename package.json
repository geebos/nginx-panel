{
  "name": "cf-next-pages-routes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,worker \"pnpm dev:web\" \"pnpm dev:worker\"",
    "dev:web": "next dev",
    "dev:worker": "wrangler dev --local --port 8787",
    "dev:sqlite": "concurrently -k -n web,worker \"pnpm dev:web\" \"pnpm dev:worker:sqlite\"",
    "dev:worker:sqlite": "DB_ENGINE=sqlite DB_SQLITE_DIR=./.sqlite tsx src/worker/serve.ts",
    "lint": "eslint",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "migrate:local": "wrangler d1 migrations apply todos --local",
    "migrate:remote": "wrangler d1 migrations apply todos --remote"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hono/node-server": "^2.0.8",
    "@hono/zod-validator": "^0.8.0",
    "@hookform/resolvers": "^5.4.0",
    "@tauri-apps/api": "~2.6.0",
    "@tauri-apps/plugin-dialog": "~2.7.1",
    "@tauri-apps/plugin-http": "~2.5.9",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "hono": "^4.12.26",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260619.1",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "~2.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "wrangler": "^4.103.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
